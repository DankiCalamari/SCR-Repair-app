# Application
APP_NAME=Sunset Country Repairs
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change-this-to-a-random-64-char-secret-key-in-production
APP_URL=http://localhost:8000

# CORS — comma-separated list of allowed origins (no trailing slash)
# Add your external access URL(s), e.g. http://192.168.1.100:8000 or https://repairs.yourdomain.com
CORS_ORIGINS=http://localhost:8000

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=sunset_repairs
POSTGRES_USER=sunset_user
POSTGRES_PASSWORD=change-this-password

# JWT
JWT_SECRET_KEY=another-random-secret-key-for-jwt-signing
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# SMS Gateway (SMS Gate)
SMS_GATEWAY_URL=https://sms.example.com/api
SMS_DEVICE_ID=
SMS_API_KEY=
SMS_WEBHOOK_SECRET=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=repairs@sunsetcountry.com.au
SMTP_FROM_NAME=Sunset Country Repairs
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/app/uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_BUCKET=
AWS_S3_BUCKET=
AWS_S3_REGION=

# Logging
LOG_LEVEL=INFO
